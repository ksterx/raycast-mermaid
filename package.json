{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "mermaid-clipboard",
  "title": "Mermaid Clipboard",
  "description": "Render a Mermaid diagram from your clipboard.",
  "icon": "extension-icon.png",
  "author": "ksterx",
  "categories": ["Developer Tools"],
  "license": "MIT",
  "commands": [
    {
      "name": "render-mermaid",
      "title": "Render Mermaid from Clipboard",
      "description": "Read Mermaid code from the clipboard and render it as a diagram.",
      "mode": "view"
    }
  ],
  "preferences": [
    {
      "name": "theme",
      "title": "Diagram Theme",
      "description": "Theme used to render the diagram.",
      "type": "dropdown",
      "required": false,
      "default": "auto",
      "data": [
        { "title": "Auto (match Raycast appearance)", "value": "auto" },
        { "title": "Default", "value": "default" },
        { "title": "Dark", "value": "dark" },
        { "title": "Neutral", "value": "neutral" },
        { "title": "Forest", "value": "forest" }
      ]
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.99.0",
    "@raycast/utils": "^1.19.1",
    "pako": "^2.1.0"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.0.4",
    "@types/node": "22.13.10",
    "@types/pako": "^2.0.3",
    "@types/react": "19.0.10",
    "eslint": "^9.22.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2"
  },
  "scripts": {
    "build": "ray build",
    "dev": "ray develop",
    "lint": "ray lint",
    "fix-lint": "ray lint --fix",
    "publish": "npx @raycast/api@latest publish"
  }
}
